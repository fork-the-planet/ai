{
	"name": "model-scraper",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "CLOUDFLARE_ENV=development vite",
		"start": "npm run dev",
		"build": "vite build",
		"preview": "npm run build && vite preview",
		"deploy": "npm run build && npm run deploy:production",
		"deploy:production": "wrangler deploy -e production",
		"deploy:staging": "wrangler deploy -e staging",
		"format": "oxfmt --write .",
		"test": "vitest",
		"cf-typegen": "wrangler types",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"test:ci": "vitest --watch=false",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@ai-sdk/openai": "^3.0.71",
		"agents": "^0.16.0",
		"ai": "^6.0.204",
		"hono": "^4.12.25",
		"workers-ai-provider": "^3.2.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.40.2",
		"@cloudflare/vitest-pool-workers": "^0.16.15",
		"oxfmt": "^0.54.0",
		"oxlint": "^1.69.0",
		"typescript": "6.0.3",
		"vite": "^8.0.16",
		"vitest": "~4.1.8",
		"wrangler": "^4.100.0"
	}
}
