{
	"name": "workers-ai-provider",
	"version": "3.1.14",
	"description": "Workers AI Provider for the vercel AI SDK",
	"keywords": [
		"ai",
		"chat",
		"cloudflare",
		"provider",
		"sdk",
		"serverless",
		"vercel",
		"workers"
	],
	"bugs": {
		"url": "https://github.com/cloudflare/ai/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git://github.com/cloudflare/ai.git"
	},
	"files": [
		"dist",
		"src",
		"README.md",
		"package.json"
	],
	"type": "module",
	"main": "dist/index.mjs",
	"types": "dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		},
		"./gateway-delegate": {
			"types": "./dist/gateway-delegate.d.mts",
			"import": "./dist/gateway-delegate.mjs"
		},
		"./openai": {
			"types": "./dist/openai.d.mts",
			"import": "./dist/openai.mjs"
		},
		"./anthropic": {
			"types": "./dist/anthropic.d.mts",
			"import": "./dist/anthropic.mjs"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "rm -rf dist && tsdown src/index.ts src/gateway-delegate.ts src/openai.ts src/anthropic.ts --dts --sourcemap --format esm --target es2020",
		"prepare": "pnpm build",
		"format": "oxfmt --write .",
		"test:ci": "vitest --watch=false",
		"test": "vitest",
		"test:e2e": "vitest --config vitest.e2e.config.ts --watch=false",
		"test:e2e:rest": "vitest --config vitest.e2e.config.ts --watch=false test/e2e/workers-ai-rest.e2e.test.ts",
		"test:e2e:binding": "vitest --config vitest.e2e.config.ts --watch=false test/e2e/workers-ai-binding.e2e.test.ts",
		"type-check": "tsc --noEmit"
	},
	"devDependencies": {
		"@ai-sdk/anthropic": "^3.0.84",
		"@ai-sdk/openai": "^3.0.71",
		"@ai-sdk/provider": "^3.0.10",
		"@cloudflare/workers-types": "^4.20260613.1",
		"ai": "^6.0.204",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"@ai-sdk/anthropic": "^3.0.0",
		"@ai-sdk/openai": "^3.0.0",
		"@ai-sdk/provider": "^3.0.0",
		"ai": "^6.0.0"
	},
	"peerDependenciesMeta": {
		"@ai-sdk/anthropic": {
			"optional": true
		},
		"@ai-sdk/openai": {
			"optional": true
		}
	},
	"authors": "Cloudflare Inc."
}
